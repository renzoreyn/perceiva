generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  baseCurrency Currency @default(USD)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions  Transaction[]
  monthlyRecaps MonthlyRecap[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Transaction {
  id               String          @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Decimal         @db.Decimal(18, 4)
  currency         Currency
  convertedAmount  Decimal         @db.Decimal(18, 4)
  exchangeRateUsed Decimal         @db.Decimal(18, 6)
  baseCurrency     Currency
  category         Category
  description      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@map("transactions")
}

model MonthlyRecap {
  id           String   @id @default(cuid())
  userId       String
  year         Int
  month        Int
  totalIncome  Decimal  @db.Decimal(18, 4)
  totalExpense Decimal  @db.Decimal(18, 4)
  netBalance   Decimal  @db.Decimal(18, 4)
  savingsRate  Decimal  @db.Decimal(8, 4)
  baseCurrency Currency
  insightsJson Json
  generatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
  @@map("monthly_recaps")
}

enum TransactionType {
  income
  expense
}

enum Currency {
  USD
  EUR
  GBP
  CNY
  IDR
  AMD
}

enum Category {
  food_drink
  transport
  shopping
  utilities
  housing
  health
  entertainment
  education
  travel
  income_salary
  income_freelance
  income_other
  other
}
