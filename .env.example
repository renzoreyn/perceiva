# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string
# Recommended: Neon (neon.tech) or Supabase (supabase.com) for Vercel
DATABASE_URL="postgresql://username:password@localhost:5432/perceiva"

# ── Authentication ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-minimum-32-chars"

# ── Currency API ──────────────────────────────────────────────────
# Free tier at: https://app.exchangerate-api.com
# 1,500 requests/month free — Perceiva caches for 1hr, ~720 req/month
CURRENCY_API_KEY="your-exchangerate-api-key"

# ── App URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Cron (optional) ───────────────────────────────────────────────
# For auto-generating monthly recaps via Vercel Cron
# Generate: openssl rand -base64 32
CRON_SECRET="your-cron-secret"
